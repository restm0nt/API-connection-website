# .env.example
# Copy this file to .env and fill in your real values.
# NEVER share your .env file or commit it to GitHub.

# Your Bito API key (from Bito platform → Settings → Integrations)
BITO_API_KEY=your_api_key_here

# API base URL (leave as is unless Bito gives you a different URL)
BITO_BASE_URL=https://api.bito.uz/integration-api/integration/api/v2

# Folder where CSV files will be saved (Power BI reads from here)
OUTPUT_DIR=data
